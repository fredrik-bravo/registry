{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "bravo",
  "homepage": "http://localhost:3000",
  "items": [
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utilities",
      "description": "Class name merging utilities for shadcn components.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "registry/laravel-inertia/lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "A typed button primitive with variants, sizes, and Radix Slot composition.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["@bravo/utils"],
      "files": [
        {
          "path": "registry/laravel-inertia/ui/button.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "dropdown-menu",
      "type": "registry:ui",
      "title": "Dropdown Menu",
      "description": "A menu primitive for grouped actions and option sets.",
      "dependencies": ["@radix-ui/react-dropdown-menu", "lucide-react"],
      "registryDependencies": ["@bravo/utils"],
      "files": [
        {
          "path": "registry/laravel-inertia/ui/dropdown-menu.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "navigation-menu",
      "type": "registry:ui",
      "title": "Navigation Menu",
