{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/components/ui/*": ["./registry/laravel-inertia/ui/*"],
      "@/components/mobile-nav": [
        "./registry/laravel-inertia/components/mobile-nav"
      ],
      "@/components/site-nav": [
        "./registry/laravel-inertia/components/site-nav"
      ],
      "@/components/theme-selector": [
        "./registry/laravel-inertia/components/theme-selector"
      ],
      "@/Components/ui/*": ["./registry/laravel-inertia/ui/*"],
      "@/Components/*": ["./registry/laravel-inertia/components/*"],
      "@/lib/*": ["./registry/laravel-inertia/lib/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
